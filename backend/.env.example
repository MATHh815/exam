# Flask 配置
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# 数据库配置
DATABASE_URL=sqlite:///exam.db
# 生产环境可以使用 PostgreSQL 或 MySQL
# DATABASE_URL=postgresql://user:password@localhost/exam_db
# DATABASE_URL=mysql+pymysql://user:password@localhost/exam_db

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 分钟
JWT_REFRESH_TOKEN_EXPIRES=604800  # 7 天

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
